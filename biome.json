{
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded",
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "trailingCommas": "none"
    }
  },
  
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },

  "linter": {
    "rules": {
      "correctness": {
        "noUnknownTypeSelector": "off"
      }
    }
  }
}