{
  "name": "nextia",
  "description": "Create fast web applications",
  "version": "7.0.12",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "author": {
    "name": "Sinuhe Maceda",
    "email": "sinuhe.dev@gmail.com",
    "url": "https://sinuhe.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sinuhedev/nextia.git"
  },
  "homepage": "https://github.com/sinuhedev/nextia",
  "keywords": [
    "react"
  ],
  "bin": {
    "nextia": "src/bin.js"
  },
  "exports": {
    ".": "./src/lib/index.js"
  },
  "scripts": {
    "clean": "rm -fr node_modules .coverage out package-lock.json",
    "format": "biome format",
    "lint": "biome lint src",
    "check": "biome check --reporter=summary src",
    "test": "vitest run",
    "test:name": "vitest run --testNamePattern",
    "test:silent": "vitest run --silent",
    "test:coverage": "vitest run --silent --coverage"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.3",
    "jsdom": "29.0.2",
    "vitest": "4.1.3"
  }
}
